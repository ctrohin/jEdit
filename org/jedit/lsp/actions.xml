<!--
  LSP completion action definitions for jEdit

  These actions are registered and can be bound to keyboard shortcuts
  via Global Options → Shortcuts or mode-specific shortcuts.

  Example binding:
  - Action: lsp-complete
  - Shortcut: Ctrl+Space
-->

<ACTIONS>
    <!-- LSP Complete Action -->
    <ACTION NAME="lsp-complete">
        <CODE>
            org.jedit.lsp.LspPlugin.completeLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP Code Actions -->
    <ACTION NAME="code-actions-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.codeActionsLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP Refactorings -->
    <ACTION NAME="refactor-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.refactorLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP Rename -->
    <ACTION NAME="rename-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.renameLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP Method Parameters (signature help) -->
    <ACTION NAME="signature-help-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.signatureHelpLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP Go to Definition -->
    <ACTION NAME="goto-definition-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.goToDefinitionLsp(view);
        </CODE>
    </ACTION>

    <!-- LSP navigation history -->
    <ACTION NAME="goto-back-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.goBackLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="goto-forward-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.goForwardLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="find-references-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.findReferencesLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="find-implementations-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.findImplementationsLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="type-definition-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.findTypeDefinitionLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="find-declaration-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.findDeclarationLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="document-symbols-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.documentSymbolsLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="workspace-symbol-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.workspaceSymbolLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="call-hierarchy-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.callHierarchyLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="show-symbol-results-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.showSymbolResults(view);
        </CODE>
    </ACTION>

    <ACTION NAME="show-structure-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.showStructure(view);
        </CODE>
    </ACTION>

    <ACTION NAME="format-document-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.formatDocumentLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="format-selection-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.formatSelectionLsp(view);
        </CODE>
    </ACTION>

    <ACTION NAME="organize-imports-lsp">
        <CODE>
            org.jedit.lsp.LspPlugin.organizeImportsLsp(view);
        </CODE>
    </ACTION>
</ACTIONS>

